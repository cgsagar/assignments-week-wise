//Approach 1 - Time complexity is O(n²)
function twoSum(arr, target){
    let count = 0;
    for(let i=0; i<arr.length; i++){
        for(let j=i+1; j<arr.length; j++){
            if(arr[i]+arr[j] === target){
                count++;
            }
        }
    }
    return count;
}

console.log(twoSum([1, 5, 7, -1, 5], 6));
